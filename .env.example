# TMDB API key — read server-side only (never shipped to the browser).
# Get one free at https://www.themoviedb.org/settings/api
# IMPORTANT: rotate the key that was hardcoded in the old static site; it is
# public in git history.
TMDB_API_KEY=your_tmdb_key_here

# Public site origin, used for canonical URLs, Open Graph, and the sitemap.
NEXT_PUBLIC_SITE_URL=https://justflixmovies.pages.dev
